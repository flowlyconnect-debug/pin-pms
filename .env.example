FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=run.py

# Generate a strong key in real environments
SECRET_KEY=replace-with-random-secret

POSTGRES_DB=pindora
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+psycopg2://postgres:replace-with-strong-password@db:5432/pindora
