FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=run.py
# Windows: if ``flask`` is not on PATH, use ``python -m flask run`` (same flags).
# Docker: use ``docker compose up -d`` to start both ``web`` and ``db``; ``exec web`` needs ``web`` running.

# Generate a strong key in real environments
SECRET_KEY=replace-with-random-secret
# Flask session lifetime (minutes) for permanent login session cookie.
SESSION_LIFETIME_MINUTES=120

POSTGRES_DB=pindora
POSTGRES_USER=postgres
# Local Flask on your machine: use 127.0.0.1 and a real password (docker compose maps db:5432).
# The ``web`` service overrides POSTGRES_HOST to ``db`` (see docker-compose.yml).
POSTGRES_HOST=127.0.0.1
# Published Docker DB port (see docker-compose.yml); avoids local Postgres on :5432.
POSTGRES_PORT=5433
POSTGRES_PASSWORD=postgres
# Do not set DATABASE_URL here unless you need a custom URL; the app builds one from POSTGRES_*.
# DATABASE_URL=  # vaihtoehto POSTGRES_*-muuttujille (template osio 18)

# Rate limits (Flask-Limiter syntax: "<count>/<period>"). Brief, section 18.
# - LOGIN_RATE_LIMIT throttles POST /login per IP to slow brute-force attempts.
# - API_RATE_LIMIT throttles every /api/v1 route per API key (per-IP when
#   unauthenticated) to protect the public API from runaway clients.
LOGIN_RATE_LIMIT=5/minute
# User-level brute-force lockout threshold in a rolling 15-minute window.
# If failed attempts for the same email exceed this value, login is blocked for 30 minutes.
MAX_LOGIN_ATTEMPTS=5
API_RATE_LIMIT=100/hour

# Mailgun outbound email (brief, section 7). MAIL_DEV_LOG_ONLY=1 turns off the
# real Mailgun call and logs the rendered email to stdout instead — handy for
# local development. Production deployments must keep MAIL_DEV_LOG_ONLY=0 and
# provide a real API key + domain.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=noreply@example.com
MAILGUN_FROM_NAME=Pindora PMS
MAILGUN_BASE_URL=https://api.mailgun.net/v3
MAIL_DEV_LOG_ONLY=1
# Outbound email queue worker (APScheduler). Keep enabled in normal runtime;
# disable only for one-off troubleshooting where background dispatch is unwanted.
EMAIL_SCHEDULER_ENABLED=1

# CORS (brief, section 10): comma-separated list of origins allowed to call
# /api/*. Leave empty to disable CORS entirely (only same-origin requests
# succeed). Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Database backups (brief, section 8). BACKUP_DIR is mounted as a Docker
# volume (see docker-compose.yml). BACKUP_SCHEDULE_CRON follows APScheduler's
# CronTrigger five-field syntax: "minute hour day month day_of_week".
# Default = 03:00 UTC every day. Set BACKUP_SCHEDULER_ENABLED=0 to disable
# automatic scheduling (manual triggers via CLI / admin UI still work).
# BACKUP_RETENTION_DAYS follows the customer template minimum (section 18).
# BACKUP_NOTIFY_EMAIL receives the backup_completed / backup_failed
# notifications; leave blank to skip the email step.
BACKUP_DIR=/var/backups/pindora
# Project brief section 8: backups also include uploaded files. The directory
# is optional — if missing or empty the uploads-archive step is skipped.
UPLOADS_DIR=/var/lib/pindora/uploads
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_CRON=0 3 * * *
BACKUP_SCHEDULER_ENABLED=1
BACKUP_NOTIFY_EMAIL=
# Optional S3-compatible off-site copy. Local backup is always kept as primary.
BACKUP_S3_ENABLED=0
BACKUP_S3_ENDPOINT_URL=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_PREFIX=pindora-pms/

# Billing: daily job marks open invoices overdue when due_date is in the past.
# Uses the same APScheduler process as backups (either job can run alone).
# CronTrigger five-field syntax. Set INVOICE_OVERDUE_SCHEDULER_ENABLED=0 to
# disable the scheduled pass (CLI `flask invoices-mark-overdue` still works).
INVOICE_OVERDUE_SCHEDULER_ENABLED=1
INVOICE_OVERDUE_SCHEDULE_CRON=30 6 * * *

# API key usage retention in days (daily APScheduler pruning job).
API_USAGE_RETENTION_DAYS=90

# Password policy minimum length (letters + numbers are also required by app policy).
PASSWORD_MIN_LENGTH=12

# Pindora lock integration (placeholder API wiring; endpoints can change when vendor docs are confirmed).
PINDORA_LOCK_BASE_URL=
PINDORA_LOCK_API_KEY=
PINDORA_LOCK_WEBHOOK_SECRET=
PINDORA_LOCK_TIMEOUT_SECONDS=10

# Optional: encrypt uploaded check-in documents at rest (Fernet urlsafe base64 key).
CHECKIN_FERNET_KEY=

# iCal calendar sync (Airbnb/Booking.com import-export).
ICAL_FEED_SECRET=
ICAL_HTTP_TIMEOUT_SECONDS=10
ICAL_SYNC_ENABLED=1
ICAL_SYNC_INTERVAL_MINUTES=15
