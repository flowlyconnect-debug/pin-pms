# --- Init template (section 18) — copy to ``.env`` and replace placeholders ---

# Flask environment: development, testing, or production
FLASK_ENV=development

# Required in production. Use a long random secret.
SECRET_KEY=replace-me

# Required in production. Example shape only (use your real DB user/host/db name).
DATABASE_URL=postgresql://user:password@localhost:5432/pindora

# Required in production for outbound email (Mailgun).
MAILGUN_API_KEY=your-key-here

# Mailgun sending domain (e.g. mg.example.com).
MAILGUN_DOMAIN=your-domain-here

# From header for transactional email.
MAILGUN_FROM_EMAIL=noreply@example.com

# Display name for the From header.
MAILGUN_FROM_NAME=Pin PMS

# Local path or container volume for database backup files.
BACKUP_DIR=/var/backups/pindora

# How many days on-disk backups are retained before pruning.
BACKUP_RETENTION_DAYS=30

# Flask-Limiter string for authenticated API routes (e.g. 100/hour).
API_RATE_LIMIT=100/hour

# Flask-Limiter string for POST /login per IP (e.g. 5/minute).
LOGIN_RATE_LIMIT=5/minute

# --- Flask / runtime (beyond section 18) ---

FLASK_DEBUG=1
FLASK_APP=run.py
# Windows: if ``flask`` is not on PATH, use ``python -m flask run`` (same flags).
# Docker: use ``docker compose up -d`` to start both ``web`` and ``db``; ``exec web`` needs ``web`` running.
# ``docker-compose.yml`` overrides ``POSTGRES_HOST=db``, ``POSTGRES_PORT=5432``, and clears
# ``DATABASE_URL`` for the ``web`` container so a host-oriented ``.env`` still works in Compose.

# Flask session lifetime (minutes) for permanent login session cookie.
SESSION_LIFETIME_MINUTES=120

POSTGRES_DB=pindora
POSTGRES_USER=postgres
# Local PostgreSQL defaults for development.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_PASSWORD=postgres
# Hosted Postgres (Render, Neon, …) requires TLS. For POSTGRES_HOST not on
# loopback/``db``, pytest and TEST_DATABASE_URL default to sslmode=require.
# Override if needed: POSTGRES_SSLMODE=prefer or POSTGRES_SSLMODE=disable
# POSTGRES_SSLMODE=require

# Optional explicit SQLAlchemy connection string. Keep empty for local dev
# so the app builds URL from POSTGRES_* variables above.
# Render example:
# DATABASE_URL=postgresql://database_admin:<PASSWORD>@<render-host>/<db-name>
# DATABASE_URL=

# Optional: password used when seeding the demo guest user (`flask seed-demo-data`).
# DEMO_GUEST_PASSWORD=replace-me

# Rate limits (Flask-Limiter syntax: "<count>/<period>"). Brief, section 18.
# - LOGIN_RATE_LIMIT throttles POST /login per IP to slow brute-force attempts.
# - API_RATE_LIMIT throttles every /api/v1 route per API key (per-IP when
#   unauthenticated) to protect the public API from runaway clients.
# LOGIN_RATE_LIMIT and API_RATE_LIMIT are also listed at the top of this file.
# User-level brute-force lockout threshold in a rolling 15-minute window.
# If failed attempts for the same email exceed this value, login is blocked for 30 minutes.
MAX_LOGIN_ATTEMPTS=5

# Mailgun outbound email (brief, section 7). MAIL_DEV_LOG_ONLY=1 turns off the
# real Mailgun call and logs the rendered email to stdout instead — handy for
# local development. Production deployments must keep MAIL_DEV_LOG_ONLY=0 and
# provide a real API key + domain.
# MAILGUN_API_KEY, MAILGUN_DOMAIN, MAILGUN_FROM_EMAIL, MAILGUN_FROM_NAME are summarized at the top.
MAILGUN_BASE_URL=https://api.mailgun.net/v3
MAIL_DEV_LOG_ONLY=1
# Outbound email queue worker (APScheduler). Keep enabled in normal runtime;
# disable only for one-off troubleshooting where background dispatch is unwanted.
EMAIL_SCHEDULER_ENABLED=1

# CORS (brief, section 10): comma-separated list of origins allowed to call
# /api/*. Leave empty to disable CORS entirely (only same-origin requests
# succeed). Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Database backups (brief, section 8). BACKUP_DIR is mounted as a Docker
# volume (see docker-compose.yml). BACKUP_SCHEDULE_CRON follows APScheduler's
# CronTrigger five-field syntax: "minute hour day month day_of_week".
# Default = 03:00 UTC every day. Set BACKUP_SCHEDULER_ENABLED=0 to disable
# automatic scheduling (manual triggers via CLI / admin UI still work).
# BACKUP_RETENTION_DAYS follows the customer template minimum (section 18).
# BACKUP_NOTIFY_EMAIL receives the backup_completed / backup_failed
# notifications; leave blank to skip the email step.
# BACKUP_DIR and BACKUP_RETENTION_DAYS are also listed at the top of this file.
# Project brief section 8: backups also include uploaded files. The directory
# is optional — if missing or empty the uploads-archive step is skipped.
UPLOADS_DIR=/var/lib/pindora/uploads
BACKUP_SCHEDULE_CRON=0 3 * * *
BACKUP_SCHEDULER_ENABLED=1
BACKUP_NOTIFY_EMAIL=
# Optional S3-compatible off-site copy. Local backup is always kept as primary.
BACKUP_S3_ENABLED=0
BACKUP_S3_ENDPOINT_URL=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_PREFIX=pindora-pms/

# Billing: daily job marks open invoices overdue when due_date is in the past.
# Uses the same APScheduler process as backups (either job can run alone).
# CronTrigger five-field syntax. Set INVOICE_OVERDUE_SCHEDULER_ENABLED=0 to
# disable the scheduled pass (CLI `flask invoices-mark-overdue` still works).
INVOICE_OVERDUE_SCHEDULER_ENABLED=1
INVOICE_OVERDUE_SCHEDULE_CRON=30 6 * * *

# API key usage retention in days (daily APScheduler pruning job).
API_USAGE_RETENTION_DAYS=90

# Password policy minimum length (letters + numbers are also required by app policy).
PASSWORD_MIN_LENGTH=12

# Pindora lock integration (placeholder API wiring; endpoints can change when vendor docs are confirmed).
PINDORA_LOCK_BASE_URL=
PINDORA_LOCK_API_KEY=
PINDORA_LOCK_WEBHOOK_SECRET=
PINDORA_LOCK_TIMEOUT_SECONDS=10

# Outbound webhook delivery retry scheduler (APScheduler).
WEBHOOK_DELIVERY_SCHEDULER_ENABLED=1
WEBHOOK_DELIVERY_RETRY_INTERVAL_SECONDS=60
WEBHOOK_HTTP_TIMEOUT_SECONDS=4
# Publish outbound webhook events asynchronously when supported
WEBHOOK_PUBLISH_ASYNC=0

# Inbound HMAC secrets are stored in the ``settings`` table as ``webhooks.stripe.secret``,
# ``webhooks.vismapay.secret``, and ``webhooks.pindora_lock.secret`` (``is_secret=true``, Fernet at rest).
IDEMPOTENCY_KEY_TTL_SECONDS=86400

# Enable scheduled pruning of expired idempotency keys
IDEMPOTENCY_PRUNE_SCHEDULER_ENABLED=1

# Cron schedule for pruning expired idempotency keys, default: 04:00 UTC daily
IDEMPOTENCY_PRUNE_SCHEDULE_CRON=0 4 * * *

# Optional: encrypt uploaded check-in documents at rest (Fernet urlsafe base64 key).
CHECKIN_FERNET_KEY=

# iCal calendar sync (Airbnb/Booking.com import-export).
ICAL_FEED_SECRET=
ICAL_HTTP_TIMEOUT_SECONDS=10
ICAL_SYNC_ENABLED=1
ICAL_SYNC_INTERVAL_MINUTES=15
APP_BASE_URL=http://127.0.0.1:5000
STATUS_SCHEDULER_ENABLED=1
LOG_LEVEL=INFO
SQL_SLOW_QUERY_MS=500
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Sentry environment name. Defaults to FLASK_ENV if empty.
SENTRY_ENVIRONMENT=
# Sentry release identifier. Defaults to git revision or development.
SENTRY_RELEASE=

# Stripe — international cards
STRIPE_ENABLED=0
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Paytrail — Finnish online banks, MobilePay and domestic cards
PAYTRAIL_ENABLED=0
PAYTRAIL_MERCHANT_ID=
PAYTRAIL_SECRET_KEY=
PAYTRAIL_API_BASE=https://services.paytrail.com

# Payments
PAYMENT_RETURN_URL=https://app.example.com/payments/return
PAYMENT_CALLBACK_URL=https://app.example.com/api/v1/webhooks/paytrail
